import { VerticalBox, HorizontalBox, Slider } from "std-widgets.slint";

// --- Reusable page header (back arrow + title) ---
component PageHeader inherits Rectangle {
    in property <string> title;
    callback go-back();

    height: 52px;
    background: #1b4f72;

    // Back arrow touch target
    Rectangle {
        x: 0px;
        y: 0px;
        width: 52px;
        height: 52px;

        Text {
            text: "\u{2190}";
            font-size: 24px;
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            clicked => {
                root.go-back();
            }
        }
    }

    Text {
        x: 52px;
        width: parent.width - 64px;
        text: root.title;
        font-size: 20px;
        font-weight: 600;
        color: #ffffff;
        vertical-alignment: center;
    }
}

// --- Badge Page (main name card display) ---
component BadgePage inherits Rectangle {
    in-out property <string> display-name: "Hebu";
    in-out property <string> tagline: "Hello from VRCBadge!";
    in-out property <string> twitter-handle: "@Hebu_VRC";
    in-out property <string> discord-handle: "hebu";
    in-out property <int> battery-percent: 100;
    in property <image> background-image;
    in property <image> avatar-image;
    in property <color> background-color: #1a1a2e;
    in property <color> tagline-color: #e0e8f0;
    in property <color> tagline-background-color: #1b4f72;

    callback open-settings();

    background: root.background-color;

    // === Background image (behind everything, only shown if uploaded) ===
    Image {
        visible: root.background-image.width > 0;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        source: root.background-image;
        image-fit: cover;
    }

    // === Layer 0: Accent bar (declared BEFORE avatar for Z-order) ===
    Rectangle {
        x: 0px;
        y: 140px;
        width: parent.width;
        height: 48px;
        background: root.tagline-background-color;

        // Tagline text on the bar
        Text {
            x: 260px;
            width: parent.width - 280px;
            text: root.tagline;
            font-size: 20px;
            font-weight: 500;
            color: root.tagline-color;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // === Layer 1: Avatar (on top of accent bar) ===
    Rectangle {
        x: 30px;
        y: 60px;
        width: 200px;
        height: 200px;
        border-radius: 20px;
        background: #2a2a4a;
        border-width: 2px;
        border-color: #3a3a5a;
        clip: true;

        Image {
            source: root.avatar-image.width > 0 ? root.avatar-image : @image-url("../images/profile/sample.png");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }
    }

    // === Layer 2: Right column content ===

    // Display name
    Text {
        x: 260px;
        y: 70px;
        width: parent.width - 320px;
        text: root.display-name;
        font-size: 36px;
        font-weight: 700;
        color: #ffffff;
        overflow: elide;
    }

    // Social handles (right-middle)

    // Twitter / X handle
    HorizontalLayout {
        x: 260px;
        y: 200px;
        height: 24px;
        spacing: 6px;
        alignment: start;

        Rectangle {
            width: 18px;
            height: 18px;

            Image {
                source: @image-url("../images/logos/twitter.png");
                width: 16px;
                height: 16px;
                x: 1px;
                y: 1px;
                image-fit: contain;
            }
        }

        Text {
            text: root.twitter-handle;
            font-size: 18px;
            color: #1da1f2;
            vertical-alignment: center;
        }
    }

    // Discord handle
    HorizontalLayout {
        x: 260px;
        y: 230px;
        height: 24px;
        spacing: 6px;
        alignment: start;

        Rectangle {
            width: 18px;
            height: 18px;

            Image {
                source: @image-url("../images/logos/discord.png");
                width: 18px;
                height: 18px;
                image-fit: contain;
            }
        }

        Text {
            text: root.discord-handle;
            font-size: 18px;
            color: #7289da;
            vertical-alignment: center;
        }
    }

    // VRChat logo (bottom-right, white, no background)
    Image {
        source: @image-url("../images/logos/vrchat.png");
        x: parent.width - 200px;
        y: parent.height - 120px;
        width: 150px;
        height: 64px;
        image-fit: contain;
    }

    // Battery indicator (bottom-right)
    Rectangle {
        x: parent.width - 160px;
        y: parent.height - 44px;
        width: 140px;
        height: 30px;

        HorizontalLayout {
            spacing: 6px;
            alignment: end;

            Text {
                text: root.battery-percent + "%";
                font-size: 16px;
                font-weight: 700;
                color: root.battery-percent > 20 ? #4caf50 : #f44336;
                vertical-alignment: center;
            }

            // Battery icon (stacked images with visibility conditions)
            Rectangle {
                width: 24px;
                height: 24px;

                Image {
                    visible: root.battery-percent > 75;
                    source: @image-url("../images/icons/battery-full.png");
                    width: 24px;
                    height: 24px;
                    image-fit: contain;
                }

                Image {
                    visible: root.battery-percent > 50 && root.battery-percent <= 75;
                    source: @image-url("../images/icons/battery-high.png");
                    width: 24px;
                    height: 24px;
                    image-fit: contain;
                }

                Image {
                    visible: root.battery-percent > 25 && root.battery-percent <= 50;
                    source: @image-url("../images/icons/battery-medium.png");
                    width: 24px;
                    height: 24px;
                    image-fit: contain;
                }

                Image {
                    visible: root.battery-percent > 10 && root.battery-percent <= 25;
                    source: @image-url("../images/icons/battery-low.png");
                    width: 24px;
                    height: 24px;
                    image-fit: contain;
                }

                Image {
                    visible: root.battery-percent <= 10;
                    source: @image-url("../images/icons/battery-empty.png");
                    width: 24px;
                    height: 24px;
                    image-fit: contain;
                }
            }
        }
    }

    // Settings gear icon (top-right touch target)
    Rectangle {
        x: parent.width - 56px;
        y: 0px;
        width: 56px;
        height: 56px;

        Image {
            source: @image-url("../images/icons/gear-six.png");
            width: 28px;
            height: 28px;
            x: 14px;
            y: 14px;
            image-fit: contain;
        }

        TouchArea {
            clicked => {
                root.open-settings();
            }
        }
    }
}

// --- Settings Page ---
component SettingsPage inherits Rectangle {
    in-out property <float> brightness: 50;

    callback go-back();
    callback open-wifi();
    callback open-logs();
    callback open-about();
    callback brightness-changed(float);

    background: #1a1a2e;

    // Header bar
    PageHeader {
        x: 0px;
        y: 0px;
        width: parent.width;
        title: "Settings";
        go-back => { root.go-back(); }
    }

    // Setting items
    VerticalLayout {
        y: 62px;
        x: 20px;
        width: parent.width - 40px;
        spacing: 0px;

        // Display Brightness
        Rectangle {
            height: 80px;
            background: transparent;

            VerticalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 6px;

                HorizontalLayout {
                    alignment: space-between;

                    Text {
                        text: "Display Brightness";
                        font-size: 18px;
                        color: #cccccc;
                        vertical-alignment: center;
                    }

                    Text {
                        text: Math.round(root.brightness) + "%";
                        font-size: 18px;
                        color: #888888;
                        vertical-alignment: center;
                    }
                }

                Slider {
                    minimum: 10;
                    maximum: 100;
                    value: root.brightness;
                    changed(value) => {
                        root.brightness = value;
                        root.brightness-changed(value);
                    }
                }
            }

            Rectangle {
                y: 79px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }

        // WiFi
        Rectangle {
            height: 56px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: "WiFi";
                    font-size: 18px;
                    color: #cccccc;
                    vertical-alignment: center;
                }

                Text {
                    text: "\u{203A}";
                    font-size: 24px;
                    color: #555580;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => {
                    root.open-wifi();
                }
            }

            Rectangle {
                y: 55px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }

        // Logs
        Rectangle {
            height: 56px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: "Logs";
                    font-size: 18px;
                    color: #cccccc;
                    vertical-alignment: center;
                }

                Text {
                    text: "\u{203A}";
                    font-size: 24px;
                    color: #555580;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => {
                    root.open-logs();
                }
            }

            Rectangle {
                y: 55px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }

        // About
        Rectangle {
            height: 56px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: "About";
                    font-size: 18px;
                    color: #cccccc;
                    vertical-alignment: center;
                }

                Text {
                    text: "\u{203A}";
                    font-size: 24px;
                    color: #555580;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => {
                    root.open-about();
                }
            }

            Rectangle {
                y: 55px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }
    }
}

// --- WiFi Info Page ---
component WiFiPage inherits Rectangle {
    in property <int> connected-clients: 0;
    in property <string> ip-address: "192.168.71.1";

    callback go-back();

    background: #1a1a2e;

    // Header bar
    PageHeader {
        x: 0px;
        y: 0px;
        width: parent.width;
        title: "WiFi";
        go-back => { root.go-back(); }
    }

    // Info rows
    VerticalLayout {
        y: 62px;
        x: 20px;
        width: parent.width - 40px;
        spacing: 0px;

        for item in [
            { label: "Mode", value: "AP Mode" },
            { label: "SSID", value: "VRCBadge" },
            { label: "IP Address", value: root.ip-address },
        ]: Rectangle {
            height: 52px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: item.label;
                    font-size: 18px;
                    color: #888888;
                    vertical-alignment: center;
                }

                Text {
                    text: item.value;
                    font-size: 18px;
                    color: #ffffff;
                    vertical-alignment: center;
                }
            }

            // Divider
            Rectangle {
                y: 51px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }

        // Connected clients (dynamic value from Rust)
        Rectangle {
            height: 52px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: "Connected Clients";
                    font-size: 18px;
                    color: #888888;
                    vertical-alignment: center;
                }

                Text {
                    text: root.connected-clients == 0 ? "None" : root.connected-clients + "";
                    font-size: 18px;
                    color: root.connected-clients > 0 ? #4caf50 : #ffffff;
                    vertical-alignment: center;
                }
            }

            // Divider
            Rectangle {
                y: 51px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }
    }
}

// --- Logs Page (scrollable log viewer) ---
component LogsPage inherits Rectangle {
    in property <string> log-text: "";

    callback go-back();

    background: #1a1a2e;

    // Header bar
    PageHeader {
        x: 0px;
        y: 0px;
        width: parent.width;
        title: "Logs";
        go-back => { root.go-back(); }
    }

    // Log viewer (full height scrollable area)
    Rectangle {
        x: 10px;
        y: 60px;
        width: parent.width - 20px;
        height: parent.height - 70px;
        background: #111122;
        border-radius: 6px;

        Flickable {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            height: parent.height - 16px;
            viewport-height: log-content.preferred-height;

            log-content := Text {
                width: parent.width;
                text: root.log-text;
                font-size: 14px;
                color: #66cc66;
                wrap: word-wrap;
            }
        }
    }
}

// --- About Page (system info) ---
component AboutPage inherits Rectangle {
    in property <string> firmware-version: "0.0.0";
    in property <string> uptime: "0s";
    in property <string> heap-free: "0 KB";
    in property <string> psram-free: "0 KB";

    callback go-back();

    background: #1a1a2e;

    // Header bar
    PageHeader {
        x: 0px;
        y: 0px;
        width: parent.width;
        title: "About";
        go-back => { root.go-back(); }
    }

    // System info rows
    VerticalLayout {
        y: 62px;
        x: 20px;
        width: parent.width - 40px;
        spacing: 0px;

        for item in [
            { label: "Firmware", value: root.firmware-version },
            { label: "Uptime", value: root.uptime },
            { label: "Heap Free", value: root.heap-free },
            { label: "PSRAM Free", value: root.psram-free },
        ]: Rectangle {
            height: 52px;
            background: transparent;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: item.label;
                    font-size: 18px;
                    color: #888888;
                    vertical-alignment: center;
                }

                Text {
                    text: item.value;
                    font-size: 18px;
                    color: #ffffff;
                    vertical-alignment: center;
                }
            }

            // Divider
            Rectangle {
                y: 51px;
                width: parent.width;
                height: 1px;
                background: #2a2a4a;
            }
        }
    }
}

// --- Main Window ---
export component BadgeUI inherits Window {
    width: 800px;
    height: 480px;
    background: #1a1a2e;

    in-out property <string> display-name: "Hebu";
    in-out property <string> tagline: "Hello from VRCBadge!";
    in-out property <string> twitter-handle: "@Hebu_VRC";
    in-out property <string> discord-handle: "hebu";
    in-out property <int> battery-percent: 85;
    in-out property <int> wifi-clients: 0;
    in-out property <string> wifi-ip: "192.168.71.1";
    in-out property <float> display-brightness: 50;
    in-out property <image> background-image;
    in-out property <image> avatar-image;
    in-out property <color> badge-background-color: #1a1a2e;
    in-out property <color> tagline-color: #e0e8f0;
    in-out property <color> tagline-background-color: #1b4f72;
    in-out property <int> current-page: 0;
    in-out property <string> firmware-version: "0.0.0";
    in-out property <string> about-uptime: "0s";
    in-out property <string> about-heap: "0 KB";
    in-out property <string> about-psram: "0 KB";
    in-out property <string> log-text: "";

    callback brightness-changed(float);

    // Badge page
    badge := BadgePage {
        visible: root.current-page == 0;
        width: parent.width;
        height: parent.height;
        display-name: root.display-name;
        tagline: root.tagline;
        twitter-handle: root.twitter-handle;
        discord-handle: root.discord-handle;
        battery-percent: root.battery-percent;
        background-image: root.background-image;
        avatar-image: root.avatar-image;
        background-color: root.badge-background-color;
        tagline-color: root.tagline-color;
        tagline-background-color: root.tagline-background-color;

        open-settings => {
            root.current-page = 1;
        }
    }

    // Settings page
    settings := SettingsPage {
        visible: root.current-page == 1;
        width: parent.width;
        height: parent.height;
        brightness: root.display-brightness;

        go-back => {
            root.current-page = 0;
        }

        open-wifi => {
            root.current-page = 2;
        }

        open-logs => {
            root.current-page = 3;
        }

        open-about => {
            root.current-page = 4;
        }

        brightness-changed(value) => {
            root.brightness-changed(value);
        }
    }

    // WiFi info page
    wifi-page := WiFiPage {
        visible: root.current-page == 2;
        width: parent.width;
        height: parent.height;
        connected-clients: root.wifi-clients;
        ip-address: root.wifi-ip;

        go-back => {
            root.current-page = 1;
        }
    }

    // Logs page
    logs-page := LogsPage {
        visible: root.current-page == 3;
        width: parent.width;
        height: parent.height;
        log-text: root.log-text;

        go-back => {
            root.current-page = 1;
        }
    }

    // About page
    about-page := AboutPage {
        visible: root.current-page == 4;
        width: parent.width;
        height: parent.height;
        firmware-version: root.firmware-version;
        uptime: root.about-uptime;
        heap-free: root.about-heap;
        psram-free: root.about-psram;

        go-back => {
            root.current-page = 1;
        }
    }
}
